# Private wallet key (DO NOT COMMIT)
PRIVATE_KEY=0x...

# Wallet address
WALLET_ADDRESS=0x...

# GitHub token for reputation calculations (optional)
GITHUB_TOKEN=ghp_...

# x402 payment recipient (where USDC payments go)
# If not set, API runs in free mode (no payments required)
PAYMENT_RECIPIENT_ADDRESS=0x...

# Contract addresses (Base Sepolia testnet)
AGENT_REGISTRY_ADDRESS=0x644337Ca322C90098b5F3657Bde2b661e28d9e0E
REPUTATION_ORACLE_ADDRESS=0xb7FaEDd691a1d9e02A348a09456F6D3E39355FF1

# RPC endpoints
BASE_SEPOLIA_RPC=https://sepolia.base.org
FILECOIN_CALIBRATION_RPC=https://api.calibration.node.glif.io/rpc/v1

# Server configuration
PORT=3000
NODE_ENV=development

# Security Warning:
# ==================
# NEVER commit .env files to git!
# Add .env to .gitignore immediately
# Use unique credentials (not from git history)
